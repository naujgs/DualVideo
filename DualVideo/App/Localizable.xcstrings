        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DualVideo necesita acceso a la cámara, el micrófono y la Fototeca para funcionar. Activa todos los permisos en Ajustes."
          }
        }
      }
    },
    "DualVideo needs microphone access to record audio. Please enable Microphone access in Settings." : {
