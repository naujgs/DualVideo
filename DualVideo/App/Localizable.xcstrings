    },
    "DualVideo requires an iPhone with an A12 Bionic chip or newer (iPhone XR, XS, or later) to record from both cameras simultaneously.\n\nThis device does not support dual-camera recording." : {
      "comment" : "Body text on unsupported-device screen explaining hardware requirements",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DualVideo requires an iPhone with an A12 Bionic chip or newer (iPhone XR, XS, or later) to record from both cameras simultaneously.\n\nThis device does not support dual-camera recording."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DualVideo requiere un iPhone con chip A12 Bionic o posterior (iPhone XR, XS o más reciente) para grabar con ambas cámaras simultáneamente.\n\nEste dispositivo no es compatible con la grabación de doble cámara."
          }
        }
      }
    },
