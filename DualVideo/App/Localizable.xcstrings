    "DualVideo doesn't have permission to save to Photos. Open Settings to allow access." : {
      "comment" : "Alert message shown when save fails due to missing photo library permission",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DualVideo doesn't have permission to save to Photos. Open Settings to allow access."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DualVideo no tiene permiso para guardar en Fotos. Abre Ajustes para permitir el acceso."
          }
        }
      }
    },
    "DualVideo needs camera access to record video. Please enable Camera access in Settings." : {
      "comment" : "Shown on permissions-blocked screen when camera permission is denied",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DualVideo needs camera access to record video. Please enable Camera access in Settings."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DualVideo necesita acceso a la cámara para grabar vídeo. Activa el acceso a la Cámara en Ajustes."
          }
        }
      }
    },
    "DualVideo needs camera, microphone, and Photo Library access to function. Please enable all permissions in Settings." : {
      "comment" : "Shown on permissions-blocked screen when an unrecognized permission category is denied",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DualVideo needs camera, microphone, and Photo Library access to function. Please enable all permissions in Settings."
